# Copy to `.env` (local), `.env.staging`, or `.env.production` and edit.
# All VITE_* values are baked into the client bundle at build time.

# --- Origins (single config layer for all environments) -----------------
# Local dev:      VITE_WEB_ORIGIN=http://localhost:8080
# Staging:        VITE_WEB_ORIGIN=https://staging.mindrop.in
# Production:     VITE_WEB_ORIGIN=https://mindrop.in
VITE_WEB_ORIGIN=https://mindrop.in

# Where the native (Android) build sends /_serverFn/* and /api/* calls.
# Usually the same as VITE_WEB_ORIGIN; override to point the APK at staging.
VITE_API_ORIGIN=https://mindrop.in

# --- Supabase (managed by Lovable Cloud — do not edit in prod) ----------
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=
